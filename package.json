{
  "name": "electron-plugin-app",
  "version": "1.0.0",
  "description": "Electron app with plugin system + device communication",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --port 6173 --strictPort",
    "dev:electron": "wait-on http://localhost:6173 && tsc --project tsconfig.json && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:main && electron-builder",
    "build:renderer": "tsc --project tsconfig.renderer.json --noEmit && vite build",
    "build:main": "tsc --project tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.renderer.json --noEmit",
    "typecheck:main": "tsc --noEmit",
    "typecheck:renderer": "tsc --project tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "electron-store": "^8.1.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^4.5.0"
  },
  "optionalDependencies": {
    "@abandonware/noble": "^1.9.2",
    "node-hid": "^3.1.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.yourapp.id",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "dist/main/**",
      "dist/renderer/**",
      "plugins/**"
    ],
    "extraResources": [
      {
        "from": "plugins",
        "to": "plugins"
      }
    ]
  }
}
