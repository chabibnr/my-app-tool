{
  "name": "electron-plugin-app",
  "version": "1.0.0",
  "description": "Electron app with plugin system + device communication",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --port 6173 --strictPort",
    "dev:electron": "wait-on http://localhost:6173 && cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "lint": "eslint src --ext .js,.jsx"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "electron-store": "^8.1.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^4.5.0"
  },
  "optionalDependencies": {
    "@abandonware/noble": "^1.9.2",
    "node-hid": "^3.1.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.yourapp.id",
    "directories": {
      "output": "dist/electron"
    },
    "files": [
      "src/main/**",
      "dist/renderer/**",
      "plugins/**"
    ],
    "extraResources": [
      {
        "from": "plugins",
        "to": "plugins"
      }
    ]
  }
}
